{
  "name": "obsidian-multisync",
  "version": "0.1.2",
  "description": "Multi-cloud folder sync for Obsidian",
  "author": "Roy",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:integration": "set INTEGRATION_TEST=1 && vitest run tests/integration",
    "test:e2e": "node tests/e2e-sync.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.23.0",
    "eslint": "^10.1.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "fake-indexeddb": "^6.2.5",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.3",
    "typescript": "^5.5.4",
    "undici": "^7.24.4",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "dropbox": "^10.34.0"
  }
}
